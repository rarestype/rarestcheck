#!/bin/bash

set -euo pipefail

AUTOSYNC_HEADER="#  ❣❣❣  DO NOT EDIT  ❣  THIS FILE IS AUTOMATICALLY SYNCED  ❣  DO NOT EDIT  ❣❣❣"

usage() {
    echo "Usage: $0 OWNER NAME [options]"
    echo
    echo "  -f | --push         push to GitHub"
    echo "  -t | --templates    templates directory"
    echo
    exit 1
}

if [[ $# -gt 1 ]]; then
    OWNER="$1"
    NAME="$2"
    REPO="${OWNER}/${NAME}"
    shift 2
else
    usage
    exit 1
fi

PUSH=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        -f | --push)
            PUSH=true
            shift
            ;;

        -t | --templates)
            TEMPLATES=$(realpath "$2")
            shift 2
            ;;

        -h | --help)
            usage
            shift
            ;;

        *)
            echo "Unknown option: $1" >&2
            usage
            ;;
    esac
done

if [[ ! -v TEMPLATES ]]; then
    echo "Error: TEMPLATES is not set." >&2
    usage
fi

xcode='26.4'
swift='6.3.1'
swift_install='rarestype/swift-install-action@v1'

# sync workflows
if [ -d .github/workflows ]; then
    # align all Swift and Xcode version numbers in (manually-written) workflows
    pattern_minor='[[:digit:]]+(\.[[:digit:]]+)?'
    pattern_patch='[[:digit:]]+\.[[:digit:]]+(\.[[:digit:]]+)?'
    pattern_swift_install='uses: rarestype/swift-install-action@[^[:space:]]+'
    pattern_swift_release="swift-release:[[:space:]]+[\"']?${pattern_patch}-RELEASE[\"']?"

    for path in .github/workflows/*.yml; do
        sed -i -E \
            -e "s|${pattern_swift_install}|uses: ${swift_install}|g" \
            -e "s|${pattern_swift_release}|swift-release: ${swift}-RELEASE|g" \
            -e "s/swift-${pattern_patch}-release/swift-${swift}-release/g" \
            -e "s/swift-${pattern_patch}-RELEASE/swift-${swift}-RELEASE/g" \
            -e "s/Xcode ${pattern_minor}/Xcode ${xcode}/g" \
            -e "s/Xcode_${pattern_minor}/Xcode_${xcode}/g" "$path"

        git add "$path"
    done
else
    mkdir -p .github/workflows
fi

# these actions only synced if already present
for template in "$TEMPLATES"/Actions/Optional/*; do
    name=${template##*/}
    path=".github/actions/${name}"
    if [ -d "$path" ]; then
        (
            echo "$AUTOSYNC_HEADER"
            echo
            cat "$template/action.yml"
        ) > "${path}/action.yml"
        git add "${path}/action.yml"
    fi
done

# these workflows only synced if already present
for template in "$TEMPLATES"/Workflows/Optional/*.yml; do
    file=${template##*/}
    name=${file%.yml}
    path=".github/workflows/${file}"
    if [ -f "$path" ]; then
        (
            echo "$AUTOSYNC_HEADER"
            echo
            cat "$template"
        ) > "$path"
        git add "$path"

        # if this workflow has children, write them too
        if [ -d "${TEMPLATES}/Workflows/Optional/${name}" ]; then
            for child in "${TEMPLATES}/Workflows/Optional/${name}"/*.yml; do
                child_file=${child##*/}
                child_path=".github/workflows/$child_file"
                (
                    echo "$AUTOSYNC_HEADER"
                    echo
                    cat "$child"
                ) > "$child_path"
                git add "$child_path"
            done
        fi
    fi
done

# these workflows always present
for template in "$TEMPLATES"/Workflows/*.yml; do
    file=${template##*/}
    name=${file%.yml}
    path=".github/workflows/$file"
    (
        echo "$AUTOSYNC_HEADER"
        echo
        cat "$template"
    ) > "$path"

    # conditional fragments
    # in the future we may support other fragments
    optional_jobs=()
    for fragment in Deploy; do
        expected="${TEMPLATES}/WorkflowFragments/${name}.${fragment}.yml"
        if [[ -f "$expected" && -f ".github/workflows/${fragment}.yml" ]]; then
            cat "$expected" >> "$path"
            optional_jobs+=("${fragment,,}")
        fi
    done
    # mandatory fragments
    for fragment in Publish; do
        expected="${TEMPLATES}/WorkflowFragments/${name}.${fragment}.yml"
        if [[ -f "$expected" ]]; then
            while IFS= read -r line || [ -n "$line" ]; do
                if [[ "$line" == *__OPTIONAL_JOBS__* ]]; then
                    # Extract the leading spaces from the placeholder
                    indent="${line%-*}"
                    for job in "${optional_jobs[@]}"; do
                        echo "${indent}-   ${job}"
                    done
                else
                    echo "$line"
                fi
            done < "$expected" >> "$path"
        fi
    done

    git add "$path"
done

# commit and push
if ! git diff --staged --exit-code --quiet ; then
    echo "files changed!"
    git config user.name "rarest automation"
    git config user.email "automation@noreply.rarestype.com"

    git commit -m "[autosync]"
    if [ "$PUSH" = true ]; then
        git push
    fi

    echo "💞 synchronized repository ${REPO}!"
else
    echo "🤍 no changes to repository ${REPO}"
fi
