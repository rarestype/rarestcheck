#!/bin/bash

set -euo pipefail

mkdir -p workspace/
cd workspace

repository=${2##*/}

if [ ! -d "$repository" ]; then
    gh repo clone "$2" -- --quiet
fi

cd "$repository"

# sync licenses (only if repo is already marked with license)
license=$(gh repo view "$2" --json licenseInfo --jq '.licenseInfo.key')
case "$license" in
    "apache-2.0")
        cp -f "$1"/Legal/Apache/LICENSE LICENSE
        git add LICENSE

        sed \
            -e "s|__REPOSITORY_NAME__|${repository}|g" \
            -e "s|__REPOSITORY_ID__|${2}|g" \
            "$1"/Legal/Apache/NOTICE > NOTICE
        git add NOTICE
        ;;

    "mpl-2.0")
        cp -f "$1"/Legal/MPL/LICENSE LICENSE
        git add LICENSE
        ;;

    *)
        ;;
esac

# sync workflows
mkdir -p .github/workflows

for template in "$1"/Workflows/*.yml; do
    name=$(basename "$template")
    file=".github/workflows/$name"
    echo "#  ❣❣❣  DO NOT EDIT  ❣  THIS FILE IS AUTOMATICALLY SYNCED  ❣  DO NOT EDIT  ❣❣❣" \
        > "$file"
    echo "" >> "$file"
    cat "$template" >> "$file"
    git add "$file"
done

if ! git diff --staged --exit-code --quiet ; then
    echo "files changed!"
    git config user.name "rarest automation"
    git config user.email "automation@noreply.rarestype.com"

    git commit -m "synchronize files from https://github.com/rarestype/rarestcheck"
    git push

    echo "💞 synchronized repository $2!"
else
    echo "🤍 no changes to repository $2"
fi
