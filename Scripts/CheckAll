#!/bin/bash

set -euo pipefail

# --source excludes forked repos
readarray -t organization < \
    <(gh repo list rarestype --source --json nameWithOwner -q '.[].nameWithOwner')
readarray -t additional < Scripts/AdditionalRepositories

any_failed=0

for id in "${organization[@]}"; do
    if ! Scripts/Check "$id"; then
        echo "❗ repository $id contains insecure email addresses!!!"
        any_failed=1
    else
        echo "💞 repository $id contains no insecure email addresses!"
    fi
done

if [ "$any_failed" -ne 0 ]; then
    echo "One or more repositories contains insecure emails!"
    exit 1
fi
