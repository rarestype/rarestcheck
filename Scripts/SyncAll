#!/bin/bash

set -euo pipefail

AUTOSYNC_HEADER="#  ❣❣❣  DO NOT EDIT  ❣  THIS FILE IS AUTOMATICALLY SYNCED  ❣  DO NOT EDIT  ❣❣❣"

usage() {
    echo "Usage: $0 [options]"
    echo
    echo "  -f | --push     push to GitHub"
    echo
    exit 1
}

sync() (
    mkdir -p workspace/
    cd workspace

    local repository=${2##*/}

    if [ ! -d "$repository" ]; then
        gh repo clone "$2" -- --quiet
    fi

    cd "$repository"

    # check the repository visibility
    local is_private=$(gh repo view "$2" --json isPrivate --jq '.isPrivate')

    # vacuum any badge refs lingering under the wrong namespace, depending on repo visibility
    if [ "$is_private" == "true" ]; then
        local target_namespace="refs/badges/ci/*"
    else
        local target_namespace="refs/tags/badges/ci/*"
    fi

    local refs_to_delete=$(git ls-remote origin "$target_namespace" | awk '{print $2}')
    if [ -n "$refs_to_delete" ]; then
        local delete_args=""
        for ref in $refs_to_delete; do
            delete_args="$delete_args :$ref"
        done

        # Only perform the remote deletion if the user passed the --push flag
        if [ "$PUSH" = true ]; then
            echo "cleaning up stale ref ${repository}:${ref}..."
            git push origin $delete_args
        else
            echo "detected stale ref ${repository}:${ref}..."
        fi
    fi

    # sync licenses (only if repo is already marked with license)
    local license=$(gh repo view "$2" --json licenseInfo --jq '.licenseInfo.key')
    case "$license" in
        "apache-2.0")
            cp -f "$1"/Legal/Apache/LICENSE LICENSE
            git add LICENSE

            sed \
                -e "s|__REPOSITORY_NAME__|${repository}|g" \
                -e "s|__REPOSITORY_ID__|${2}|g" \
                "$1"/Legal/Apache/NOTICE > NOTICE
            git add NOTICE
            ;;

        "mpl-2.0")
            cp -f "$1"/Legal/MPL/LICENSE LICENSE
            git add LICENSE
            ;;

        *)
            ;;
    esac

    # sync workflows
    mkdir -p .github/workflows

    # these workflows only synced if already present
    for template in "$1"/Workflows/Optional/*.yml; do
        local file=${template##*/}
        local name=${file%.yml}
        local path=".github/workflows/$file"
        if [ -f "$path" ]; then
            (
                echo "$AUTOSYNC_HEADER"
                echo
                cat "$template"
            ) > "$path"
            git add "$path"

            # if this workflow has children, write them too
            if [ -d "$1"/Workflows/Optional/"$name" ]; then
                for child in "$1"/Workflows/Optional/"$name"/*.yml; do
                    local child_file=${child##*/}
                    local child_path=".github/workflows/$child_file"
                    (
                        echo "$AUTOSYNC_HEADER"
                        echo
                        cat "$child"
                    ) > "$child_path"
                    git add "$child_path"
                done
            fi
        fi
    done

    # these workflows always present
    for template in "$1"/Workflows/*.yml; do
        local file=${template##*/}
        local name=${file%.yml}
        local path=".github/workflows/$file"
        (
            echo "$AUTOSYNC_HEADER"
            echo
            cat "$template"
        ) > "$path"

        # in the future we may support other fragments
        for fragment in Deploy; do
            local expected="${1}/WorkflowFragments/${name}.${fragment}.yml"
            if [[ -f "$expected" && -f ".github/workflows/${fragment}.yml" ]]; then
                cat "$expected" >> "$path"
            fi
        done

        git add "$path"
    done

    # sync FUNDING.yml
    local funding_yml=".github/FUNDING.yml"
    echo "$AUTOSYNC_HEADER" > "$funding_yml"
    cat "$1/FUNDING.yml" >> "$funding_yml"
    git add "$funding_yml"

    # sync README.md, if present
    if [ -f README.md ]; then
        python3 ../../Scripts/SyncReadme.py "$2" \
            --readme README.md \
            --labels "$1/StatusLabels.txt" \
            --is-private "$is_private"
        git add README.md
    fi

    # commit and push
    if ! git diff --staged --exit-code --quiet ; then
        echo "files changed!"
        git config user.name "rarest automation"
        git config user.email "automation@noreply.rarestype.com"

        git commit -m "[autosync]"
        if [ "$PUSH" = true ]; then
            git push
        fi

        echo "💞 synchronized repository $2!"
    else
        echo "🤍 no changes to repository $2"
    fi
)

PUSH=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        -f | --push)
            PUSH=true
            shift
            ;;

        *)
            echo "Unknown option: $1" >&2
            usage
            ;;
    esac
done

tag='autosync'

# --source excludes forked repos
readarray -t organization < \
    <(gh repo list rarestype --source --topic "$tag" --json nameWithOwner -q '.[].nameWithOwner')
readarray -t additional_unfiltered < Scripts/AdditionalRepositories

additional=()
for repo in "${additional_unfiltered[@]}"; do
    # skip empty lines
    if [ -z "$repo" ]; then continue; fi

    if gh api "repos/$repo" --jq '.topics[]' | grep -Fxq "$tag"; then
        additional+=("$repo")
    fi
done

templates=$(realpath Templates)

for id in "${organization[@]}" "${additional[@]}"; do
    # we do not want to push to this repo itself
    if [ "$id" != 'rarestype/rarestcheck' ]; then
        sync "$templates" "$id"
    fi
done
