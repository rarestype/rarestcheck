#!/bin/bash

set -euo pipefail

AUTOSYNC_HEADER="#  ❣❣❣  DO NOT EDIT  ❣  THIS FILE IS AUTOMATICALLY SYNCED  ❣  DO NOT EDIT  ❣❣❣"

usage() {
    echo "Usage: $0 [options]"
    echo
    echo "  -f | --push     push to GitHub"
    echo
    exit 1
}

sync() (
    mkdir -p workspace/
    cd workspace

    local repository=${2##*/}

    if [ ! -d "$repository" ]; then
        gh repo clone "$2" -- --quiet
    fi

    cd "$repository"

    # sync licenses (only if repo is already marked with license)
    local license=$(gh repo view "$2" --json licenseInfo --jq '.licenseInfo.key')
    case "$license" in
        "apache-2.0")
            cp -f "$1"/Legal/Apache/LICENSE LICENSE
            git add LICENSE

            sed \
                -e "s|__REPOSITORY_NAME__|${repository}|g" \
                -e "s|__REPOSITORY_ID__|${2}|g" \
                "$1"/Legal/Apache/NOTICE > NOTICE
            git add NOTICE
            ;;

        "mpl-2.0")
            cp -f "$1"/Legal/MPL/LICENSE LICENSE
            git add LICENSE
            ;;

        *)
            ;;
    esac

    # sync workflows
    mkdir -p .github/workflows

    # these workflows only synced if already present
    for template in "$1"/Workflows/Optional/*.yml; do
        local file=${template##*/}
        local name=${file%.yml}
        local path=".github/workflows/$file"
        if [ -f "$path" ]; then
            (
                echo "$AUTOSYNC_HEADER"
                echo
                cat "$template"
            ) > "$path"
            git add "$path"
        fi
    done

    # these workflows always present
    for template in "$1"/Workflows/*.yml; do
        local file=${template##*/}
        local name=${file%.yml}
        local path=".github/workflows/$file"
        (
            echo "$AUTOSYNC_HEADER"
            echo
            cat "$template"
        ) > "$path"

        # in the future we may support other fragments
        for fragment in Deploy; do
            local expected="${1}/WorkflowFragments/${name}.${fragment}.yml"
            if [[ -f "$expected" && -f ".github/workflows/${fragment}.yml" ]]; then
                cat "$expected" >> "$path"
            fi
        done

        git add "$path"
    done

    # sync FUNDING.yml
    local funding_yml=".github/FUNDING.yml"
    echo "$AUTOSYNC_HEADER" > "$funding_yml"
    cat "$1/FUNDING.yml" >> "$funding_yml"
    git add "$funding_yml"

    # commit and push
    if ! git diff --staged --exit-code --quiet ; then
        echo "files changed!"
        git config user.name "rarest automation"
        git config user.email "automation@noreply.rarestype.com"

        git commit -m "[autosync]"
        if [ "$PUSH" = true ]; then
            git push
        fi

        echo "💞 synchronized repository $2!"
    else
        echo "🤍 no changes to repository $2"
    fi
)

PUSH=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        -f | --push)
            PUSH=true
            shift
            ;;

        *)
            echo "Unknown option: $1" >&2
            usage
            ;;
    esac
done

tag='autosync'

# --source excludes forked repos
readarray -t organization < \
    <(gh repo list rarestype --source --topic "$tag" --json nameWithOwner -q '.[].nameWithOwner')
readarray -t additional_unfiltered < Scripts/AdditionalRepositories

additional=()
for repo in "${additional_unfiltered[@]}"; do
    # skip empty lines
    if [ -z "$repo" ]; then continue; fi

    if gh api "repos/$repo" --jq '.topics[]' | grep -Fxq "$tag"; then
        additional+=("$repo")
    fi
done

templates=$(realpath Templates)

for id in "${organization[@]}" "${additional[@]}"; do
    # we do not want to push to this repo itself
    if [ "$id" != 'rarestype/rarestcheck' ]; then
        sync "$templates" "$id"
    fi
done
